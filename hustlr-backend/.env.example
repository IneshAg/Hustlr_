# HUSTLR BACKEND ENVIRONMENT VARIABLES

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Browser / Flutter web (e.g. Vercel): restrict CORS to your site. Comma-separated origins.
# Leave unset or * for allow-all (default). Example: https://hustlr.vercel.app,https://www.yourdomain.com
# CORS_ORIGIN=

# Weather API Keys
OWM_API_KEY=your_openweathermap_api_key_here
AQICN_API_KEY=your_aqicn_api_key_here
WAQI_API_KEY=your_waqi_api_key_here
TOMORROW_API_KEY=your_tomorrow_io_api_key_here
OPENAQ_API_KEY=your_openaq_api_key_here

# Location & fraud — MaxMind GeoIP2 City (GeoLite2 free tier: both Account ID + License key)
# https://www.maxmind.com/en/accounts/current/license-key — required together for live IP checks on /claims/*
MAXMIND_ACCOUNT_ID=your_maxmind_account_id_here
MAXMIND_LICENSE_KEY=your_maxmind_license_key_here

# Unwired Labs — https://unwiredlabs.com (optional; used if OPENCELLID fails / unset)
CELL_LOCATION_API_KEY=your_cell_location_api_key_here
# OpenCelliD — https://opencellid.org (optional; tried first in POST /workers/cell-locate)
OPENCELLID_API_KEY=

# Ookla for Enterprise — Network Intelligence API (paid / contract; NOT a free tier)
# Default internet signal in platform_service is inferred (no Ookla call). To use live zone health:
#   OOKLA_API_KEY=<token from Ookla>  AND  USE_OOKLA_INTERNET=true
# Leave USE_OOKLA_INTERNET unset or false to avoid billing — SIMULATE_BLACKOUT=true still tests blackout UX
# OOKLA_API_KEY=
# USE_OOKLA_INTERNET=false

OPENROUTE_API_KEY=your_openroute_api_key_here
TOMTOM_API_KEY=your_tomtom_api_key_here

# News API
NEWSAPI_KEY=your_newsapi_key_here
NEWSDATA_API_KEY=your_newsdata_api_key_here

# Firebase Configuration
FIREBASE_SERVER_KEY=your_firebase_server_key_here

# Disruption cron (optional) — polls zones and inserts into disruption_events when triggers fire
# DISABLE_DISRUPTION_CRON=true
# MONITORED_ZONES=Adyar,Velachery,OMR
# DISRUPTION_CRON_SCHEDULE=*/15 * * * *
# DISRUPTION_CRON_DEDUP_MINUTES=90
# RUN_DISRUPTION_CRON_ON_BOOT=true
# DEFAULT_CITY=Chennai

# Zone depth hub (Haversine rings vs dark store)
# DARK_STORE_LAT=12.982
# DARK_STORE_LON=80.243
# USE_POSTGIS_ZONE_DEPTH=true — use Supabase RPC hustlr_zone_depth (run schema_phase2.sql)

# Predictive nudge FCM after disruption cron (optional)
# DISABLE_PREDICTIVE_NUDGE_PUSH=true
# PREDICTIVE_NUDGE_COOLDOWN_MS=21600000

# Durable notification delivery (free-tier safe defaults)
# HIGH_PRIORITY_EVENT_TTL_MINUTES=60
# NOTIFICATION_MAX_ATTEMPTS=3
# NOTIFICATION_RETRY_CRON=*/3 * * * *
# NOTIFICATION_RETRY_BATCH_SIZE=25
# NOTIFICATION_DEGRADE_DUE_BACKLOG_THRESHOLD=1000
# NOTIFICATION_DEGRADE_BATCH_SIZE=8
# NOTIFICATION_HARD_STOP_DUE_BACKLOG_THRESHOLD=5000

# Regional intelligence weekly snapshot (city risk profiles → regional_intelligence_snapshots)
# DISABLE_REGIONAL_WEEKLY_CRON=true
# REGIONAL_CRON_SCHEDULE=30 6 * * 1
# RUN_REGIONAL_CRON_ON_BOOT=true

# ── Google Play Integrity (Android) ─────────────────────────────────────────
#
# Judge-safe demo (no payment / no Google decode): mock verdict + real fraud hooks
# ───────────────────────────────────────────────────────────────────────────
# PLAY_INTEGRITY_SIMULATED=true
#   → POST /integrity/play/verify returns mock JSON (e.g. MEETS_DEVICE_INTEGRITY).
#   → Any non-empty integrity_token is enough; optional body: simulate_integrity_fail=true for +30 fraud demo.
#   → Fraud score: pass → base − 10, fail → base + 30 (on /claims/create and /claims/manual when token sent).
# Say to judges: "Integrated at architecture level; simulated responses for hackathon; production swaps to
# Google decodeIntegrityToken + service account — we do not claim tamper-proof or fully secured."
# Do NOT fabricate real Google API logs.
#
# Production path (real Google)
# ───────────────────────────────────────────────────────────────────────────
# 1) Enable "Play Integrity API" on the GCP project linked in Play Console → API access.
# 2) PLAY_INTEGRITY_SIMULATED=false (or unset) + service account JSON.
# 3) Flutter Android: --dart-define=PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER=<numeric project #>
#
# PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# PLAY_INTEGRITY_PACKAGE_NAME=com.shieldgig.shieldgig
# PLAY_INTEGRITY_BYPASS_DEV=true   # local: skip verify (any non-empty token passes /verify)
# PLAY_INTEGRITY_SKIP_NONCE_CHECK=true  # skip nonce binding (less secure)
# PLAY_INTEGRITY_REQUIRED_FOR_MANUAL=false  # true = reject manual claim without passing integrity
# PLAY_INTEGRITY_RELAXED_APP=true   # production testing: UNRECOGNIZED_VERSION
# PLAY_INTEGRITY_RELAXED_DEVICE=true  # emulators / weak device verdict

# Guidewire-style stub (set ENABLE_GUIDEWIRE_ROUTES=true to expose /guidewire/*)
# ENABLE_GUIDEWIRE_ROUTES=false
# GUIDEWIRE_WEBHOOK_URL=
# GUIDEWIRE_WEBHOOK_SECRET=

# Payouts — when true, verifies Razorpay REST keys before wallet credit (no UPI transfer yet)
# USE_REAL_PAYOUT=false
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Payment sandbox — PayPal is the recommended test provider for the app checkout demo.
# Without keys, /payments/sandbox/* still works in mock mode so the full purchase flow can be tested.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_SANDBOX_EMAIL=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=

# ISS — blend Open-Meteo historical heavy-rain prior into flood risk (extra network call)
# USE_ISS_WEATHER_PRIOR=false

# ── Render.com (see repo root render.yaml) ─────────────────────────────────
# ML_SERVICE_URL is wired automatically from hustlr-ml → hustlr-api in the Blueprint.
# Still set SUPABASE_* (and OWM, NEWS, etc.) in the Render Dashboard for hustlr-api.
